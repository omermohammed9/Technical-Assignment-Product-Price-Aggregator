# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/aggregator_db

# ── Auth ─────────────────────────────────────────────────────────────────────
# x-api-key header value required on all API endpoints
API_KEY=supersecureapikey123

# ── Aggregation ───────────────────────────────────────────────────────────────
# How often to fetch from all providers (milliseconds). Default: 5 minutes
DATA_FETCH_INTERVAL=300000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Redis Caching ─────────────────────────────────────────────────────────────
# Redis connection string. For Docker, use redis://redis:6379. For local, use redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Global request throttle TTL (milliseconds) and limit
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

